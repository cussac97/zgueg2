{%- comment -%}
  Positionnement libre d'un sous-bloc dans une diapositive (section Diaporama flexible).
  Sort une liste de custom properties CSS à injecter dans l'attribut style du root du bloc,
  consommées par .card__text--free > .slide-pos (voir theme.css).
  N'émet rien si la disposition libre est désactivée ou si le bloc est en "flux normal".

  Paramètres :
    free_layout : section.settings.free_layout (booléen)
    block       : le bloc courant (utilise slide_pos, slide_pos_mobile, slide_offset_x, slide_offset_y)
{%- endcomment -%}
{%- if free_layout and block.settings.slide_pos != blank and block.settings.slide_pos != 'flow' -%}
  {%- liquid
    assign ox = block.settings.slide_offset_x | default: 0
    assign oy = block.settings.slide_offset_y | default: 0

    # --- Ordinateur ---
    assign v = block.settings.slide_pos | split: ' ' | first
    assign h = block.settings.slide_pos | split: ' ' | last

    assign top = 'auto'
    assign bottom = 'auto'
    assign ty = '0%'
    assign oys = oy
    case v
      when 'top'
        assign top = '0'
      when 'middle'
        assign top = '50%'
        assign ty = '-50%'
      else
        assign bottom = '0'
        assign oys = 0 | minus: oy
    endcase

    assign left = 'auto'
    assign right = 'auto'
    assign tx = '0%'
    assign oxs = ox
    case h
      when 'left'
        assign left = '0'
      when 'center'
        assign left = '50%'
        assign tx = '-50%'
      else
        assign right = '0'
        assign oxs = 0 | minus: ox
    endcase
  -%}
  --sp-top:{{ top }};--sp-right:{{ right }};--sp-bottom:{{ bottom }};--sp-left:{{ left }};--sp-tx:{{ tx }};--sp-ty:{{ ty }};--sp-ox:{{ oxs }}px;--sp-oy:{{ oys }}px;
  {%- liquid
    assign mob = block.settings.slide_pos_mobile
    if mob != blank and mob != 'inherit'
      assign vm = mob | split: ' ' | first
      assign hm = mob | split: ' ' | last

      assign topm = 'auto'
      assign bottomm = 'auto'
      assign tym = '0%'
      assign oysm = oy
      case vm
        when 'top'
          assign topm = '0'
        when 'middle'
          assign topm = '50%'
          assign tym = '-50%'
        else
          assign bottomm = '0'
          assign oysm = 0 | minus: oy
      endcase

      assign leftm = 'auto'
      assign rightm = 'auto'
      assign txm = '0%'
      assign oxsm = ox
      case hm
        when 'left'
          assign leftm = '0'
        when 'center'
          assign leftm = '50%'
          assign txm = '-50%'
        else
          assign rightm = '0'
          assign oxsm = 0 | minus: ox
      endcase
      echo '--sp-top-m:' | append: topm | append: ';--sp-right-m:' | append: rightm | append: ';--sp-bottom-m:' | append: bottomm | append: ';--sp-left-m:' | append: leftm | append: ';--sp-tx-m:' | append: txm | append: ';--sp-ty-m:' | append: tym | append: ';--sp-ox-m:' | append: oxsm | append: 'px;--sp-oy-m:' | append: oysm | append: 'px;'
    endif
  -%}
{%- endif -%}
