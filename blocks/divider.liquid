{%- capture slide_pos_style -%}{%- render 'slide-position', block: block, free_layout: section.settings.free_layout -%}{%- endcapture -%}
<span
  class="divider divider--{{ block.settings.width }}{% if slide_pos_style != blank %} slide-pos{% endif %}"
  aria-hidden="true"
  style="
    {{ slide_pos_style }}
    --divider-height: {{ block.settings.height }}px;
    --divider-color: {{ block.settings.color }};
    --divider-style: {{ block.settings.style }};
  "
  >&nbsp;</span
>

{% schema %}
{
  "name": "t:divider.label",
  "class": "divider-container",
  "settings": [
    {
      "type": "range",
      "id": "height",
      "label": "t:divider.divider_height",
      "unit": "px",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 1
    },
    {
      "type": "select",
      "id": "width",
      "label": "t:theme_blocks.divider.divider_width",
      "options": [
        {
          "value": "small",
          "label": "t:theme_blocks.divider.option_1"
        },
        {
          "value": "medium",
          "label": "t:theme_blocks.divider.option_2"
        },
        {
          "value": "large",
          "label": "t:theme_blocks.divider.option_3"
        },
        {
          "value": "full",
          "label": "t:theme_blocks.divider.option_4"
        }
      ],
      "default": "small"
    },
    {
      "type": "color",
      "id": "color",
      "label": "t:divider.divider_color",
      "default": "#000000"
    },
    {
      "type": "select",
      "id": "style",
      "label": "t:sections.local-extra-words.sections.main-product.blocks.pickup_availability.settings.style",
      "options": [
        {
          "value": "solid",
          "label": "t:divider.divider_style_solid"
        },
        {
          "value": "dotted",
          "label": "t:divider.divider_style_dotted"
        },
        {
          "value": "dashed",
          "label": "t:divider.divider_style_dashed"
        },
        {
          "value": "double",
          "label": "t:divider.divider_style_double"
        }
      ],
      "default": "solid"
    },
    {
      "type": "header",
      "content": "Position dans la diapositive",
      "info": "Actif uniquement quand « Disposition libre » est coché sur le diaporama flexible.",
      "visible_if": "{{ section.settings.free_layout }}"
    },
    {
      "type": "select",
      "id": "slide_pos",
      "label": "Position (ordinateur)",
      "visible_if": "{{ section.settings.free_layout }}",
      "options": [
        { "value": "flow", "label": "Flux normal" },
        { "value": "top left", "label": "Haut gauche", "group": "Haut" },
        { "value": "top center", "label": "Haut centre", "group": "Haut" },
        { "value": "top right", "label": "Haut droite", "group": "Haut" },
        { "value": "middle left", "label": "Milieu gauche", "group": "Milieu" },
        { "value": "middle center", "label": "Milieu centre", "group": "Milieu" },
        { "value": "middle right", "label": "Milieu droite", "group": "Milieu" },
        { "value": "bottom left", "label": "Bas gauche", "group": "Bas" },
        { "value": "bottom center", "label": "Bas centre", "group": "Bas" },
        { "value": "bottom right", "label": "Bas droite", "group": "Bas" }
      ],
      "default": "flow"
    },
    {
      "type": "range",
      "id": "slide_offset_x",
      "label": "Décalage horizontal",
      "info": "Marge depuis le bord ancré, vers l'intérieur.",
      "min": -200,
      "max": 200,
      "step": 2,
      "default": 0,
      "unit": "px",
      "visible_if": "{{ section.settings.free_layout and block.settings.slide_pos != 'flow' }}"
    },
    {
      "type": "range",
      "id": "slide_offset_y",
      "label": "Décalage vertical",
      "info": "Marge depuis le bord ancré, vers l'intérieur.",
      "min": -200,
      "max": 200,
      "step": 2,
      "default": 0,
      "unit": "px",
      "visible_if": "{{ section.settings.free_layout and block.settings.slide_pos != 'flow' }}"
    },
    {
      "type": "select",
      "id": "slide_pos_mobile",
      "label": "Position (mobile)",
      "visible_if": "{{ section.settings.free_layout and block.settings.slide_pos != 'flow' }}",
      "options": [
        { "value": "inherit", "label": "Comme l'ordinateur" },
        { "value": "top left", "label": "Haut gauche", "group": "Haut" },
        { "value": "top center", "label": "Haut centre", "group": "Haut" },
        { "value": "top right", "label": "Haut droite", "group": "Haut" },
        { "value": "middle left", "label": "Milieu gauche", "group": "Milieu" },
        { "value": "middle center", "label": "Milieu centre", "group": "Milieu" },
        { "value": "middle right", "label": "Milieu droite", "group": "Milieu" },
        { "value": "bottom left", "label": "Bas gauche", "group": "Bas" },
        { "value": "bottom center", "label": "Bas centre", "group": "Bas" },
        { "value": "bottom right", "label": "Bas droite", "group": "Bas" }
      ],
      "default": "inherit"
    }
  ],
  "presets": [
    {
      "name": "t:divider.label"
    }
  ]
}
{% endschema %}
