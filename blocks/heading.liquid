{%- unless block.settings.heading == blank -%}
  {%- capture slide_pos_style -%}{%- render 'slide-position', block: block, free_layout: section.settings.free_layout -%}{%- endcapture -%}
  <{{ block.settings.seo_h_tag }}
    class="{{ block.settings.title_size }} text-line-height--{{  block.settings.line_height }}{% if slide_pos_style != blank %} slide-pos{% endif %}"
    style="{{ slide_pos_style }}{% if block.settings.text_color != 'rgba(0,0,0,0)' %}color: {{ block.settings.text_color }};{% endif %}"
  >
    {{ block.settings.heading | replace: '[br]', '<br>' }}
  </{{ block.settings.seo_h_tag }}>
{%- endunless -%}

{% schema %}
{
  "name": "t:sections.local-extra-words.sections.headings.heading",
  "class": "remove-empty-space",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:theme_blocks.caption.settings.content",
      "default": "Heading",
      "info": "t:theme_blocks.heading.settings.info"
    },
    {
      "type": "select",
      "id": "title_size",
      "label": "t:sections.rich-text.blocks.heading.settings.heading_size.label",
      "options": [
        {
          "value": "h4",
          "label": "t:sections.local-extra-words.settings_schema.product-card.title-size.options__1"
        },
        {
          "value": "h3",
          "label": "t:sections.rich-text.blocks.heading.settings.heading_size.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.rich-text.blocks.heading.settings.heading_size.options__2.label"
        },
        {
          "value": "h1",
          "label": "t:sections.rich-text.blocks.heading.settings.heading_size.options__3.label"
        }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "line_height",
      "label": "t:sections.split-extra-words.settings_schema.typography.settings.line_height",
      "options": [
        {
          "value": "default",
          "label": "t:theme_blocks.heading.settings.option_1"
        },
        {
          "value": "small",
          "label": "t:sections.local-extra-words.sections.popups.blocks.settings.size.option_1"
        },
        {
          "value": "medium",
          "label": "t:sections.image-with-text.settings.text_width.options__1.label"
        }
      ],
      "default": "default"
    },
    {
      "type": "header",
      "content": "t:sections.split-extra-words.settings_schema.colors.headings.custom_colors"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:sections.local-extra-words.settings_schema.product-card.badges.custom_badges.text_color",
      "default": "rgba(0,0,0,0)"
    },
    {
      "type": "header",
      "content": "t:sections.refactor_words.seo.name"
    },
    {
      "type": "select",
      "id": "seo_h_tag",
      "label": "t:sections.refactor_words.seo.label",
      "info": "t:sections.refactor_words.seo.info",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "span",
          "label": "span"
        }
      ],
      "default": "h3"
    },
    {
      "type": "header",
      "content": "Position dans la diapositive",
      "info": "Actif uniquement quand « Disposition libre » est coché sur le diaporama flexible.",
      "visible_if": "{{ section.settings.free_layout }}"
    },
    {
      "type": "select",
      "id": "slide_pos",
      "label": "Position (ordinateur)",
      "visible_if": "{{ section.settings.free_layout }}",
      "options": [
        { "value": "flow", "label": "Flux normal" },
        { "value": "top left", "label": "Haut gauche", "group": "Haut" },
        { "value": "top center", "label": "Haut centre", "group": "Haut" },
        { "value": "top right", "label": "Haut droite", "group": "Haut" },
        { "value": "middle left", "label": "Milieu gauche", "group": "Milieu" },
        { "value": "middle center", "label": "Milieu centre", "group": "Milieu" },
        { "value": "middle right", "label": "Milieu droite", "group": "Milieu" },
        { "value": "bottom left", "label": "Bas gauche", "group": "Bas" },
        { "value": "bottom center", "label": "Bas centre", "group": "Bas" },
        { "value": "bottom right", "label": "Bas droite", "group": "Bas" }
      ],
      "default": "flow"
    },
    {
      "type": "range",
      "id": "slide_offset_x",
      "label": "Décalage horizontal",
      "info": "Marge depuis le bord ancré, vers l'intérieur.",
      "min": -200,
      "max": 200,
      "step": 2,
      "default": 0,
      "unit": "px",
      "visible_if": "{{ section.settings.free_layout and block.settings.slide_pos != 'flow' }}"
    },
    {
      "type": "range",
      "id": "slide_offset_y",
      "label": "Décalage vertical",
      "info": "Marge depuis le bord ancré, vers l'intérieur.",
      "min": -200,
      "max": 200,
      "step": 2,
      "default": 0,
      "unit": "px",
      "visible_if": "{{ section.settings.free_layout and block.settings.slide_pos != 'flow' }}"
    },
    {
      "type": "select",
      "id": "slide_pos_mobile",
      "label": "Position (mobile)",
      "visible_if": "{{ section.settings.free_layout and block.settings.slide_pos != 'flow' }}",
      "options": [
        { "value": "inherit", "label": "Comme l'ordinateur" },
        { "value": "top left", "label": "Haut gauche", "group": "Haut" },
        { "value": "top center", "label": "Haut centre", "group": "Haut" },
        { "value": "top right", "label": "Haut droite", "group": "Haut" },
        { "value": "middle left", "label": "Milieu gauche", "group": "Milieu" },
        { "value": "middle center", "label": "Milieu centre", "group": "Milieu" },
        { "value": "middle right", "label": "Milieu droite", "group": "Milieu" },
        { "value": "bottom left", "label": "Bas gauche", "group": "Bas" },
        { "value": "bottom center", "label": "Bas centre", "group": "Bas" },
        { "value": "bottom right", "label": "Bas droite", "group": "Bas" }
      ],
      "default": "inherit"
    }
  ],
  "presets": [
    {
      "name": "t:sections.local-extra-words.sections.headings.heading",
      "settings": {
        "heading": "Heading"
      }
    }
  ]
}
{% endschema %}
