{%- capture slide_pos_style -%}{%- render 'slide-position', block: block, free_layout: section.settings.free_layout -%}{%- endcapture -%}
<div class="block-image{% if slide_pos_style != blank %} slide-pos{% endif %}" style="--image-height: {{ block.settings.image_height }}px;{{ slide_pos_style }}" {{ block.shopify_attributes }}>
  {%- if block.settings.link -%}
    <a
      href="{{ block.settings.link }}"
      {% unless block.settings.open_in_new_window == false %}
        target="_blank"
      {% endunless %}
    >
  {%- endif -%}

  {%- liquid
    assign height = block.settings.image_height
    assign height_x2 = height | times: 2
    assign height_x3 = height | times: 3
    assign aspect_ratio = block.settings.image.aspect_ratio
    assign width = height | times: aspect_ratio | round
  -%}

  <figure class="block-image__figure">
    {%- if block.settings.image != blank -%}
      <img
        src="{{ block.settings.image | image_url: height: height }}"
        srcset="
          {{ block.settings.image | image_url: height: height }} {{ width }}w,
          {{ block.settings.image | image_url: height: height_x2 }} {{ width | times: 2 }}w,
          {{ block.settings.image | image_url: height: height_x3 }} {{ width | times: 3 }}w
        "
        sizes="(max-width: 467px) {{ width | times: 0.5 }}px, (max-width: 767px) {{ width | times: 0.75 }}px, {{ width }}px"
        alt="{{ block.settings.image.alt | escape }}"
        height="{{ height }}"
        width="{{ width }}"
        loading="lazy"
        onload="this.parentNode.classList.add('lazyloaded')"
      >
    {%- else -%}
      <span class="onboarding-svg" style="background:white">
        {{ 'image' | placeholder_svg_tag }}
      </span>
    {%- endif -%}
  </figure>

  {%- if block.settings.link -%}
    </a>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "t:sections.gallery.blocks.image.settings.image.label",
  "settings": [
    {
      "id": "image",
      "type": "image_picker",
      "label": "t:sections.gallery.blocks.image.settings.image.label"
    },
    {
      "id": "image_height",
      "type": "range",
      "label": "t:divider.divider_height",
      "min": 40,
      "max": 240,
      "step": 2,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:sections.local-extra-words.sections.announcement-bar.blocks.content.settings.link"
    },
    {
      "type": "checkbox",
      "id": "open_in_new_window",
      "visible_if": "{{ block.settings.link != blank }}",
      "label": "t:sections.local-extra-words.sections.announcement-bar.blocks.content.settings.target",
      "default": false
    },
    {
      "type": "header",
      "content": "Position dans la diapositive",
      "info": "Actif uniquement quand « Disposition libre » est coché sur le diaporama flexible.",
      "visible_if": "{{ section.settings.free_layout }}"
    },
    {
      "type": "select",
      "id": "slide_pos",
      "label": "Position (ordinateur)",
      "visible_if": "{{ section.settings.free_layout }}",
      "options": [
        { "value": "flow", "label": "Flux normal" },
        { "value": "top left", "label": "Haut gauche", "group": "Haut" },
        { "value": "top center", "label": "Haut centre", "group": "Haut" },
        { "value": "top right", "label": "Haut droite", "group": "Haut" },
        { "value": "middle left", "label": "Milieu gauche", "group": "Milieu" },
        { "value": "middle center", "label": "Milieu centre", "group": "Milieu" },
        { "value": "middle right", "label": "Milieu droite", "group": "Milieu" },
        { "value": "bottom left", "label": "Bas gauche", "group": "Bas" },
        { "value": "bottom center", "label": "Bas centre", "group": "Bas" },
        { "value": "bottom right", "label": "Bas droite", "group": "Bas" }
      ],
      "default": "flow"
    },
    {
      "type": "range",
      "id": "slide_offset_x",
      "label": "Décalage horizontal",
      "info": "Marge depuis le bord ancré, vers l'intérieur.",
      "min": -200,
      "max": 200,
      "step": 2,
      "default": 0,
      "unit": "px",
      "visible_if": "{{ section.settings.free_layout and block.settings.slide_pos != 'flow' }}"
    },
    {
      "type": "range",
      "id": "slide_offset_y",
      "label": "Décalage vertical",
      "info": "Marge depuis le bord ancré, vers l'intérieur.",
      "min": -200,
      "max": 200,
      "step": 2,
      "default": 0,
      "unit": "px",
      "visible_if": "{{ section.settings.free_layout and block.settings.slide_pos != 'flow' }}"
    },
    {
      "type": "select",
      "id": "slide_pos_mobile",
      "label": "Position (mobile)",
      "visible_if": "{{ section.settings.free_layout and block.settings.slide_pos != 'flow' }}",
      "options": [
        { "value": "inherit", "label": "Comme l'ordinateur" },
        { "value": "top left", "label": "Haut gauche", "group": "Haut" },
        { "value": "top center", "label": "Haut centre", "group": "Haut" },
        { "value": "top right", "label": "Haut droite", "group": "Haut" },
        { "value": "middle left", "label": "Milieu gauche", "group": "Milieu" },
        { "value": "middle center", "label": "Milieu centre", "group": "Milieu" },
        { "value": "middle right", "label": "Milieu droite", "group": "Milieu" },
        { "value": "bottom left", "label": "Bas gauche", "group": "Bas" },
        { "value": "bottom center", "label": "Bas centre", "group": "Bas" },
        { "value": "bottom right", "label": "Bas droite", "group": "Bas" }
      ],
      "default": "inherit"
    }
  ],
  "presets": [
    {
      "name": "t:sections.gallery.blocks.image.settings.image.label"
    }
  ]
}
{% endschema %}
