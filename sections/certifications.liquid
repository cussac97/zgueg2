      "min": 6,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "button_padding_h",
      "label": "Marge intérieure horizontale",
      "min": 10,
      "max": 80,
      "step": 2,
