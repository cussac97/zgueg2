      "default": "400"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Couleur du titre",
      "info": "Transparent = couleur du thème.",
      "default": "rgba(0,0,0,0)"
    },
    {
      "type": "select",
      "id": "section_heading_layout",
      "label": "Disposition du titre",
      "options": [
        { "value": "section-heading--left section-heading--one-row", "label": "À gauche, une ligne" },
        { "value": "section-heading--left section-heading--two-rows", "label": "À gauche, deux lignes" },
        { "value": "section-heading--center section-heading--two-rows", "label": "Centré" }
      ],
