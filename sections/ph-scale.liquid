      "label": "Lien du bouton"
    },
    {
      "type": "header",
      "content": "Échelle de pH"
    },
    {
      "type": "range",
      "id": "ph_min",
      "label": "pH minimum de l'échelle",
      "min": 0,
      "max": 7,
      "step": 1,
      "default": 0
    },
    {
      "type": "range",
      "id": "ph_max",
      "label": "pH maximum de l'échelle",
      "min": 7,
      "max": 14,
      "step": 1,
      "default": 14
    },
    {
      "type": "checkbox",
      "id": "show_axis",
      "label": "Afficher l'axe (graduations et libellés)",
      "default": true
    },
    {
      "type": "text",
      "id": "axis_label_left",
