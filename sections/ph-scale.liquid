{{ 'section-ph-scale.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign s = section.settings
  assign ph_min = s.ph_min
  assign ph_max = s.ph_max
  assign range_f = ph_max | minus: ph_min | times: 1.0
  if range_f <= 0
    assign range_f = 1
  endif

  assign neutral_in_range = false
  if s.show_neutral and ph_min <= 7 and ph_max >= 7
    assign neutral_in_range = true
    assign npos = 7 | minus: ph_min | divided_by: range_f | round: 4
  endif

  assign show_ideal = s.show_ideal
  if show_ideal
    assign imin = s.ideal_min | replace: ',', '.' | times: 1.0
    assign imax = s.ideal_max | replace: ',', '.' | times: 1.0
    assign istart = imin | minus: ph_min | divided_by: range_f | round: 4
    assign iend = imax | minus: ph_min | divided_by: range_f | round: 4
    if istart < 0
      assign istart = 0
    endif
    if iend > 1
      assign iend = 1
    endif
    assign ideal_mid = istart | plus: iend | divided_by: 2.0 | round: 4
    if iend <= istart
      assign show_ideal = false
    endif
  endif

  assign scale_classes = 'ph-scale ' | append: s.value_font
-%}

<div id="section-{{ section.id }}" class="ph-scale-section">
  {%- style -%}
    #section-{{ section.id }} {
      {%- if s.section_background != blank %}
      --phs-section-bg: {{ s.section_background }};
      {%- endif %}
      --phs-table-bg: {{ s.table_background }};
      --phs-text: {{ s.text_color }};
      --phs-value-color: {{ s.value_color }};
      --phs-line: {{ s.line_color }};
      --phs-track: {{ s.track_color }};
      --phs-ideal: {{ s.ideal_color }};
      --phs-hl-bg: {{ s.highlight_background }};
      --phs-hl-border: {{ s.highlight_border }};
      --phs-hl-color: {{ s.highlight_text }};
      --phs-hl-bw: {{ s.highlight_border_width }}px;
      --phs-radius: {{ s.border_radius }}px;
      --phs-pad-y: {{ s.row_padding_y }}px;
      --phs-pad-x: {{ s.row_padding_x }}px;
      --phs-first-col: {{ s.first_col_width }}%;
      --phs-marker: {{ s.marker_size }}px;
      --phs-label-size: {{ s.label_size }}px;
      --phs-value-size: {{ s.value_size }}px;
      --phs-axis-size: {{ s.axis_size }}px;
      --phs-footnote-size: {{ s.footnote_size }}px;
    }

    #section-{{ section.id }} .section-heading__title {
      font-family: var(--font-stack-headings-primary);
      font-weight: {{ s.heading_weight }};
      font-size: {{ s.heading_size_mobile }}px;
      line-height: 1.1;
      letter-spacing: -0.01em;
      {%- if s.heading_color != blank and s.heading_color != 'rgba(0,0,0,0)' %}
      color: {{ s.heading_color }};
      {%- endif %}
    }

    @media screen and (min-width: 750px) {
      #section-{{ section.id }} .section-heading__title {
        font-size: {{ s.heading_size }}px;
      }
    }
  {%- endstyle -%}

  <div class="container--large container--vertical-space{% if s.gutter_decrease %}-small{% endif %} remove-empty-space">
    {%- render 'section-heading',
      heading: s.heading,
      subheading: s.subheading,
      section_layout: s.section_heading_layout,
      button: s.cta_label,
      button_label: s.cta_label,
      link: s.cta_url,
      seo_h_tag: s.seo_h_tag
    -%}

    <div class="{{ scale_classes }}">
      {%- if s.show_axis -%}
        <div class="ph-scale__axis-row">
          <div class="ph-scale__axis-spacer" aria-hidden="true"></div>
          <div class="ph-scale__axis">
            {%- if show_ideal and s.ideal_label != blank -%}
              <span class="ph-scale__axis-ideal" style="--p: {{ ideal_mid }};">{{ s.ideal_label | escape }}</span>
            {%- endif -%}
            {%- if s.axis_label_left != blank or s.axis_label_right != blank -%}
              <div class="ph-scale__axis-words">
                <span>{{ s.axis_label_left | escape }}</span>
                <span>{{ s.axis_label_right | escape }}</span>
              </div>
            {%- endif -%}
            <span class="ph-scale__axis-tick" style="--p: 0;">{{ ph_min }}</span>
            {%- if neutral_in_range -%}
              <span class="ph-scale__axis-tick ph-scale__axis-tick--neutral" style="--p: {{ npos }};">7</span>
            {%- endif -%}
            <span class="ph-scale__axis-tick" style="--p: 1;">{{ ph_max }}</span>
          </div>
        </div>
      {%- endif -%}

      <div class="ph-scale__rows">
        {%- for block in section.blocks -%}
          {%- liquid
            assign num = block.settings.ph_value | replace: ',', '.' | times: 1.0
            assign pos = num | minus: ph_min | divided_by: range_f | round: 4
            if pos < 0
              assign pos = 0
            endif
            if pos > 1
              assign pos = 1
            endif
            assign row_class = 'ph-scale__row'
            if block.settings.highlight
              assign row_class = row_class | append: ' is-brand'
            endif
          -%}
          <div class="{{ row_class }}" style="--pos: {{ pos }};" {{ block.shopify_attributes }}>
            <div class="ph-scale__name">{{ block.settings.label | escape }}</div>
            <div class="ph-scale__track">
              {%- if show_ideal -%}
                <span class="ph-scale__ideal" style="--s: {{ istart }}; --e: {{ iend }};" aria-hidden="true"></span>
              {%- endif -%}
              <span class="ph-scale__baseline" aria-hidden="true"></span>
              {%- if neutral_in_range -%}
                <span class="ph-scale__neutral" aria-hidden="true"></span>
              {%- endif -%}
              <span class="ph-scale__marker">
                <span class="ph-scale__value">{{ block.settings.ph_value | escape }}</span>
                <span class="ph-scale__connector" aria-hidden="true"></span>
                <span class="ph-scale__dot" aria-hidden="true"></span>
              </span>
            </div>
          </div>
        {%- endfor -%}
      </div>

      {%- if s.footnote != blank -%}
        <div class="ph-scale__footnote">{{ s.footnote }}</div>
      {%- endif -%}
    </div>
  </div>

  {%- render 'section-footer',
    button: s.cta_label,
    button_label: s.cta_label,
    link: s.cta_url
  -%}
</div>

{% schema %}
{
