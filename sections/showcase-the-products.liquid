{{ 'section-showcase-the-products.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign s = section.settings
  assign grid_classes = 'showcase-products__grid'
  if s.value_font == 'showcase-products--mono'
    assign mono_class = ' showcase-products--mono'
  else
    assign mono_class = ''
  endif
-%}

<div id="section-{{ section.id }}" class="showcase-products-section{{ mono_class }}">
  {%- style -%}
    #section-{{ section.id }} {
      {%- if s.section_background != blank %}
      --sp-section-bg: {{ s.section_background }};
      {%- endif %}
      --sp-card-bg: {{ s.card_background }};
      --sp-media-bg: {{ s.media_background }};
      --sp-text: {{ s.text_color }};
      --sp-muted: {{ s.muted_color }};
      --sp-line: {{ s.line_color }};
      --sp-hl-bg: {{ s.highlight_background }};
      --sp-hl-border: {{ s.highlight_border }};
      --sp-hl-color: {{ s.highlight_text }};
      --sp-hl-bw: {{ s.highlight_border_width }}px;
      --sp-radius: {{ s.border_radius }}px;
      --sp-gap: {{ s.card_gap }}px;
      --sp-pad: {{ s.card_padding }}px;
      --sp-min: {{ s.card_min_width }}px;
      --sp-name-size: {{ s.name_size }}px;
      --sp-tagline-size: {{ s.tagline_size }}px;
      --sp-detail-size: {{ s.detail_size }}px;
      --sp-price-size: {{ s.price_size }}px;
      --sp-ratio: {{ s.media_ratio }};
      --sp-pt: {{ s.padding_top }}px;
      --sp-pb: {{ s.padding_bottom }}px;
    }

    #section-{{ section.id }} .section-heading__title {
      font-family: var(--font-stack-headings-primary);
      font-weight: {{ s.heading_weight }};
      font-size: {{ s.heading_size_mobile }}px;
      line-height: 1.1;
      letter-spacing: -0.01em;
      {%- if s.heading_color != blank %}
        {%- assign hc_alpha = s.heading_color | color_extract: 'alpha' -%}
        {%- if hc_alpha != 0 %}
      color: {{ s.heading_color }};
        {%- endif %}
      {%- endif %}
    }

    @media screen and (min-width: 750px) {
      #section-{{ section.id }} .section-heading__title {
        font-size: {{ s.heading_size }}px;
      }
    }

    {%- comment -%} Bouton plein (carte mise en avant) {%- endcomment -%}
    {%- assign bsb_alpha = s.button_solid_bg | color_extract: 'alpha' -%}
    {%- if s.button_solid_bg != blank and bsb_alpha != 0 -%}
      #section-{{ section.id }} .showcase-products__card .button--solid {
        background-color: {{ s.button_solid_bg }};
        border-color: {{ s.button_solid_bg }};
      }
    {%- endif -%}
    {%- assign bst_alpha = s.button_solid_text | color_extract: 'alpha' -%}
    {%- if s.button_solid_text != blank and bst_alpha != 0 -%}
      #section-{{ section.id }} .showcase-products__card .button--solid,
      #section-{{ section.id }} .showcase-products__card .button--solid .button__text {
        color: {{ s.button_solid_text }};
      }
      #section-{{ section.id }} .showcase-products__card .button--solid path {
        fill: {{ s.button_solid_text }};
      }
    {%- endif -%}

    {%- comment -%} Bouton contour (carte standard) {%- endcomment -%}
    {%- assign boc_alpha = s.button_outline_color | color_extract: 'alpha' -%}
    {%- if s.button_outline_color != blank and boc_alpha != 0 -%}
      #section-{{ section.id }} .showcase-products__card .button--outline {
        border-color: {{ s.button_outline_color }};
      }
      #section-{{ section.id }} .showcase-products__card .button--outline,
      #section-{{ section.id }} .showcase-products__card .button--outline .button__text {
        color: {{ s.button_outline_color }};
      }
      #section-{{ section.id }} .showcase-products__card .button--outline path {
        fill: {{ s.button_outline_color }};
      }
    {%- endif -%}
  {%- endstyle -%}

  <div class="container--large remove-empty-space">
    {%- render 'section-heading',
      heading: s.heading,
      subheading: s.subheading,
      section_layout: s.section_heading_layout,
      button: s.cta_label,
      button_label: s.cta_label,
      link: s.cta_url,
      seo_h_tag: s.seo_h_tag
    -%}

    <div class="{{ grid_classes }}">
      {%- for block in section.blocks -%}
        {%- liquid
          assign product = block.settings.product

          assign card_name = block.settings.name
          if card_name == blank and product != blank
            assign card_name = product.title
          endif

          assign card_url = block.settings.button_url
          if card_url == blank and product != blank
            assign card_url = product.url
          endif

          assign card_image = block.settings.image
          if card_image == blank and product != blank
            assign card_image = product.featured_image
          endif

          assign card_price = block.settings.price_override
          if card_price == blank and product != blank
            assign card_price = product.price | money
          endif

          assign card_class = 'showcase-products__card'
          if block.settings.highlight
            assign card_class = card_class | append: ' is-highlight'
          endif
        -%}
        <div class="{{ card_class }}" {{ block.shopify_attributes }}>
          <div class="showcase-products__media">
            {%- if block.settings.badge != blank -%}
              <span class="showcase-products__badge">{{ block.settings.badge | escape }}</span>
            {%- endif -%}
            {%- if card_image != blank -%}
              {{ card_image | image_url: width: 900 | image_tag: class: 'showcase-products__image', loading: 'lazy', widths: '300, 450, 600, 900', alt: card_name }}
            {%- else -%}
              <div class="showcase-products__image-placeholder">
                {{ 'product-1' | placeholder_svg_tag: 'showcase-products__placeholder-svg' }}
              </div>
            {%- endif -%}
          </div>

          <div class="showcase-products__body">
            <div class="showcase-products__head">
              {%- if block.settings.eyebrow != blank -%}
                <span class="showcase-products__eyebrow">{{ block.settings.eyebrow | escape }}</span>
              {%- endif -%}
              {%- if card_name != blank -%}
                <span class="showcase-products__name">{{ card_name | escape }}</span>
              {%- endif -%}
              {%- if block.settings.tagline != blank -%}
                <p class="showcase-products__tagline">{{ block.settings.tagline | escape }}</p>
              {%- endif -%}
            </div>

            {%- if block.settings.details != blank -%}
              <ul class="showcase-products__details" role="list">
                {%- assign detail_lines = block.settings.details | newline_to_br | split: '<br />' -%}
                {%- for line in detail_lines -%}
                  {%- assign trimmed = line | strip | strip_newlines -%}
                  {%- if trimmed != blank -%}
                    <li class="showcase-products__detail">
                      {%- if trimmed contains '|' -%}
                        {%- assign parts = trimmed | split: '|' -%}
                        <span class="showcase-products__detail-key">{{ parts[0] | strip | escape }}</span>
                        <span class="showcase-products__detail-val">{{ parts[1] | strip | escape }}</span>
                      {%- else -%}
                        <span class="showcase-products__detail-key">{{ trimmed | escape }}</span>
                      {%- endif -%}
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            {%- endif -%}

            <div class="showcase-products__footer">
              {%- if card_price != blank -%}
                <span class="showcase-products__price">{{ card_price }}</span>
              {%- endif -%}
              {%- if card_url != blank -%}
                {%- assign btn_label = block.settings.button_label | default: 'Découvrir' -%}
                {%- if block.settings.highlight -%}
                  {%- assign btn_style = 'solid' -%}
                {%- else -%}
                  {%- assign btn_style = 'outline' -%}
                {%- endif -%}
                {%- render 'button',
                  label: btn_label,
                  link: card_url,
                  style: btn_style,
                  type: 'link',
                  icon: 'arrow-right',
                  text_size: 'small'
                -%}
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- if s.footnote != blank -%}
      <div class="showcase-products__footnote">{{ s.footnote }}</div>
    {%- endif -%}
  </div>

  {%- render 'section-footer',
    button: s.cta_label,
    button_label: s.cta_label,
    link: s.cta_url
  -%}
</div>

{% schema %}
{
  "name": "Showcase produits",
  "max_blocks": 4,
  "settings": [
    {
      "type": "header",
      "content": "Titre de section"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Nos best-sellers"
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "Sous-titre",
      "default": "Deux essentiels, un même geste."
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Taille du titre",
      "min": 24,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 52
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Taille du titre sur mobile",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Graisse du titre",
      "options": [
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Normal (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" }
      ],
      "default": "400"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Couleur du titre",
      "info": "Transparent = couleur du thème.",
      "default": "rgba(0,0,0,0)"
    },
    {
      "type": "select",
      "id": "section_heading_layout",
      "label": "Disposition du titre",
      "options": [
        { "value": "section-heading--left section-heading--one-row", "label": "À gauche, une ligne" },
        { "value": "section-heading--left section-heading--two-rows", "label": "À gauche, deux lignes" },
        { "value": "section-heading--center section-heading--two-rows", "label": "Centré" }
      ],
      "default": "section-heading--left section-heading--one-row"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Texte du bouton"
    },
    {
      "type": "url",
      "id": "cta_url",
      "visible_if": "{{ section.settings.cta_label != blank }}",
      "label": "Lien du bouton"
    },
    {
      "type": "header",
      "content": "Note de bas de section"
    },
    {
      "type": "richtext",
      "id": "footnote",
      "label": "Note"
    },
    {
      "type": "header",
      "content": "Valeurs"
    },
    {
      "type": "select",
      "id": "value_font",
      "label": "Police des détails et prix",
      "options": [
        { "value": "showcase-products--mono", "label": "Monospace (fidèle au design)" },
        { "value": "showcase-products--text", "label": "Police du thème" }
      ],
      "default": "showcase-products--mono"
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color_background",
      "id": "section_background",
      "label": "Fond de la section"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Fond des cartes",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "media_background",
      "label": "Fond de l'image",
      "default": "#F5F5F3"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Texte",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Texte secondaire et détails",
      "default": "#4F4F4F"
    },
    {
      "type": "color",
      "id": "line_color",
      "label": "Lignes et bordures",
      "default": "#E6E6E6"
    },
    {
      "type": "color",
      "id": "highlight_background",
      "label": "Fond de la carte mise en avant",
      "default": "#E8EDFB"
    },
    {
      "type": "color",
      "id": "highlight_border",
      "label": "Bordure de la carte mise en avant",
      "default": "#2545D3"
    },
    {
      "type": "color",
      "id": "highlight_text",
      "label": "Accent de la carte mise en avant",
      "default": "#2545D3"
    },
    {
      "type": "header",
      "content": "Bouton « Découvrir »"
    },
    {
      "type": "paragraph",
      "content": "Transparent = couleurs de bouton du thème. La carte mise en avant utilise le bouton plein, les autres le bouton contour."
    },
    {
      "type": "color",
      "id": "button_solid_bg",
      "label": "Bouton plein — fond",
      "default": "rgba(0,0,0,0)"
    },
    {
      "type": "color",
      "id": "button_solid_text",
      "label": "Bouton plein — texte",
      "default": "rgba(0,0,0,0)"
    },
    {
      "type": "color",
      "id": "button_outline_color",
      "label": "Bouton contour — bordure et texte",
      "default": "rgba(0,0,0,0)"
    },
    {
      "type": "header",
      "content": "Style des cartes"
    },
    {
      "type": "range",
      "id": "highlight_border_width",
      "label": "Épaisseur de la bordure mise en avant",
      "min": 1,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Arrondi des angles",
      "min": 0,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Espace entre les cartes",
      "min": 0,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Marge intérieure des cartes",
      "min": 12,
      "max": 56,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "select",
      "id": "media_ratio",
      "label": "Format de l'image",
      "options": [
        { "value": "1 / 1", "label": "Carré (1:1)" },
        { "value": "4 / 5", "label": "Portrait (4:5)" },
        { "value": "3 / 4", "label": "Portrait haut (3:4)" },
        { "value": "16 / 10", "label": "Paysage (16:10)" }
      ],
      "default": "4 / 5"
    },
    {
      "type": "header",
      "content": "Typographie"
    },
    {
      "type": "range",
      "id": "name_size",
      "label": "Taille du nom de produit",
      "min": 16,
      "max": 36,
      "step": 1,
      "unit": "px",
      "default": 22
    },
    {
      "type": "range",
      "id": "tagline_size",
      "label": "Taille du sous-texte",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "detail_size",
      "label": "Taille des détails",
      "min": 11,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "range",
      "id": "price_size",
      "label": "Taille du prix",
      "min": 14,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "header",
      "content": "Mise en page"
    },
    {
      "type": "range",
      "id": "card_min_width",
      "label": "Largeur minimale d'une carte",
      "info": "Sous cette largeur, les cartes passent sur une seule colonne.",
      "min": 220,
      "max": 480,
      "step": 10,
      "unit": "px",
      "default": 320
    },
    {
      "type": "header",
      "content": "Espacement"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Espace en haut",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Espace en bas",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "SEO"
    },
    {
      "type": "select",
      "id": "seo_h_tag",
      "label": "Balise du titre",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "span", "label": "span" }
      ],
      "default": "h2"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Produit",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Produit",
          "info": "Image, nom, prix et lien sont repris automatiquement. Vous pouvez tout remplacer ci-dessous."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image (remplace celle du produit)"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Étiquette au-dessus du nom",
          "default": "Best-seller"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Nom (remplace celui du produit)"
        },
        {
          "type": "text",
          "id": "tagline",
          "label": "Sous-texte",
          "default": "Une phrase qui décrit le produit."
        },
        {
          "type": "textarea",
          "id": "details",
          "label": "Détails",
          "info": "Une ligne = un détail. Utilisez « | » pour séparer libellé et valeur, ex : pH | 5,5",
          "default": "pH | 5,5\nFormat | 100 ml\nFabriqué en France"
        },
        {
          "type": "text",
          "id": "price_override",
          "label": "Prix (remplace celui du produit)"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge sur l'image"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Texte du bouton",
          "default": "Découvrir"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Lien du bouton (remplace celui du produit)"
        },
        {
          "type": "checkbox",
          "id": "highlight",
          "label": "Mettre en avant",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Showcase produits",
      "category": "t:sections-categories.storytelling",
      "blocks": [
        {
          "type": "product",
          "settings": {
            "eyebrow": "Best-seller",
            "name": "Spray intime",
            "tagline": "Fraîcheur immédiate, à emporter partout.",
            "details": "pH | 5,5\nFormat | 100 ml\nSans alcool\nFabriqué en France",
            "badge": "N°1",
            "button_label": "Découvrir",
            "highlight": true
          }
        },
        {
          "type": "product",
          "settings": {
            "eyebrow": "Best-seller",
            "name": "Gel intime",
            "tagline": "Toilette douce au quotidien.",
            "details": "pH | 5,5\nFormat | 200 ml\nSans savon\nFabriqué en France",
            "button_label": "Découvrir",
            "highlight": false
          }
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header"]
  }
}
{% endschema %}
