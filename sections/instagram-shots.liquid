{%- liquid
  assign heading_color = section.settings.heading_color
-%}

{% style %}
  #shopify-section-{{ section.id }} {
    {% if section.settings.background_color != "rgba(0,0,0,0)" %}background-color: {{ section.settings.background_color }};{% endif %}
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
  }
  #shopify-section-{{ section.id }} .ig-shots__heading {
    text-align: center;
    margin: 0 0 {{ section.settings.heading_spacing }}px;
    {% if heading_color != "rgba(0,0,0,0)" %}color: {{ heading_color }};{% endif %}
    font-size: clamp(1.75rem, 4vw, 3rem);
    line-height: 1.15;
  }
  #shopify-section-{{ section.id }} .ig-shots__row {
    display: flex;
    flex-wrap: nowrap;
    justify-content: center;
    justify-content: safe center;
    align-items: flex-start;
    gap: {{ section.settings.gap_vertical }}px {{ section.settings.gap_horizontal }}px;
    overflow-x: auto;
    scroll-snap-type: x proximity;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    padding-bottom: 6px;
  }
  #shopify-section-{{ section.id }} .ig-shots__row::-webkit-scrollbar {
    height: 6px;
  }
  #shopify-section-{{ section.id }} .ig-shots__row::-webkit-scrollbar-thumb {
    background: rgba(0, 0, 0, 0.18);
    border-radius: 999px;
  }
  #shopify-section-{{ section.id }} .ig-shots__item {
    flex: 1 1 0;
    min-width: {{ section.settings.card_min_width | default: 180 }}px;
    max-width: {{ section.settings.card_width | default: 230 }}px;
    scroll-snap-align: center;
  }
  @media screen and (max-width: 740px) {
    #shopify-section-{{ section.id }} .ig-shots__item {
      min-width: {{ section.settings.card_min_width_mobile | default: 150 }}px;
    }
  }
  #shopify-section-{{ section.id }} .ig-shots__card {
    position: relative;
    display: block;
    border-radius: 14px;
    overflow: hidden;
    line-height: 0;
  }
  #shopify-section-{{ section.id }} .ig-shots__card img,
  #shopify-section-{{ section.id }} .ig-shots__card svg.placeholder-svg {
    width: 100%;
    height: auto;
    display: block;
  }
  #shopify-section-{{ section.id }} .ig-shots__card--cover img,
  #shopify-section-{{ section.id }} .ig-shots__card--cover svg.placeholder-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  #shopify-section-{{ section.id }} .ig-shots__handle {
    position: absolute;
    top: 0.7rem;
    left: 0.7rem;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    color: #fff;
    font-size: 0.8rem;
    line-height: 1;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.45);
  }
  #shopify-section-{{ section.id }} .ig-shots__handle svg {
    width: 1rem;
    height: 1rem;
    flex: 0 0 auto;
  }
{% endstyle %}

<div class="container--large">
  {%- unless section.settings.heading == blank -%}
    <h2 class="ig-shots__heading">{{ section.settings.heading | escape }}</h2>
  {%- endunless -%}

  {%- if section.blocks.size > 0 -%}
    <div class="ig-shots__row">
      {%- for block in section.blocks -%}
        {%- liquid
          assign rot = 0
          if section.settings.tilt_images
            assign rot = block.settings.rotation
          endif

          assign ratio_css = ''
          case block.settings.ratio
            when '1:1'
              assign ratio_css = 'aspect-ratio: 1 / 1;'
            when '4:3'
              assign ratio_css = 'aspect-ratio: 4 / 3;'
            when '9:16'
              assign ratio_css = 'aspect-ratio: 9 / 16;'
          endcase
          assign card_class = 'ig-shots__card'
          unless ratio_css == ''
            assign card_class = 'ig-shots__card ig-shots__card--cover'
          endunless
        -%}
        <div
          class="ig-shots__item"
          style="transform: rotate({{ rot }}deg); margin-top: {{ block.settings.offset_y }}px;"
          {{ block.shopify_attributes }}
        >
          {%- capture card_inner -%}
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 600 }}"
                srcset="{{ block.settings.image | image_url: width: 300 }} 300w, {{ block.settings.image | image_url: width: 600 }} 600w, {{ block.settings.image | image_url: width: 900 }} 900w"
                sizes="(max-width: 740px) {{ section.settings.card_min_width_mobile | default: 150 }}px, {{ section.settings.card_width | default: 230 }}px"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
                loading="lazy"
                alt="{{ block.settings.image.alt | escape }}"
              >
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}

            {%- unless block.settings.username == blank -%}
              <span class="ig-shots__handle">
                {%- if section.settings.show_instagram_icon -%}
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
                    <rect x="2.5" y="2.5" width="19" height="19" rx="5.5" stroke="currentColor" stroke-width="2"/>
                    <circle cx="12" cy="12" r="4.5" stroke="currentColor" stroke-width="2"/>
                    <circle cx="17.6" cy="6.4" r="1.3" fill="currentColor"/>
                  </svg>
                {%- endif -%}
                {{ block.settings.username | escape }}
              </span>
            {%- endunless -%}
          {%- endcapture -%}

          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="{{ card_class }}" style="{{ ratio_css }}" target="_blank" rel="noopener">{{ card_inner }}</a>
          {%- else -%}
            <div class="{{ card_class }}" style="{{ ratio_css }}">{{ card_inner }}</div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Instagram shots",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Sur Instagram"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Couleur du titre",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Couleur de fond",
      "default": "#f7f3ec"
    },
    {
      "type": "header",
      "content": "Hauteur et espacements"
    },
    {
      "type": "paragraph",
      "content": "Padding = espace intérieur, DANS le fond coloré. Marge = espace extérieur, HORS du fond (entre cette section et les voisines). Une marge négative rapproche les sections et supprime le blanc."
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding haut (dans le fond)",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bas (dans le fond)",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Marge haute (hors fond)",
      "min": -100,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Marge basse (hors fond)",
      "min": -100,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "Espace sous le titre",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "card_width",
      "label": "Largeur maximale d'une photo",
      "info": "Les photos remplissent la largeur disponible sans jamais dépasser cette taille.",
      "min": 120,
      "max": 360,
      "step": 5,
      "unit": "px",
      "default": 230
    },
    {
      "type": "range",
      "id": "card_min_width",
      "label": "Largeur minimale (ordinateur)",
      "info": "En dessous de cette largeur, les photos défilent en slider au lieu de rétrécir.",
      "min": 100,
      "max": 320,
      "step": 5,
      "unit": "px",
      "default": 180
    },
    {
      "type": "range",
      "id": "card_min_width_mobile",
      "label": "Largeur minimale (mobile)",
      "info": "Largeur minimale d'une photo sur mobile avant le passage en slider.",
      "min": 80,
      "max": 300,
      "step": 5,
      "unit": "px",
      "default": 150
    },
    {
      "type": "range",
      "id": "gap_horizontal",
      "label": "Espace horizontal entre photos",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "gap_vertical",
      "label": "Espace vertical entre photos",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "checkbox",
      "id": "show_instagram_icon",
      "label": "Afficher l'icône Instagram",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "tilt_images",
      "label": "Activer la rotation des photos",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "photo",
      "name": "Photo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "ratio",
          "label": "Ratio de la photo",
          "options": [
            { "value": "natural", "label": "Original" },
            { "value": "1:1", "label": "1:1 (carré)" },
            { "value": "4:3", "label": "4:3" },
            { "value": "9:16", "label": "9:16 (portrait)" }
          ],
          "default": "natural"
        },
        {
          "type": "text",
          "id": "username",
          "label": "Nom d'utilisateur",
          "default": "username"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Lien (optionnel)"
        },
        {
          "type": "header",
          "content": "Position de cette photo"
        },
        {
          "type": "range",
          "id": "rotation",
          "label": "Rotation",
          "min": -20,
          "max": 20,
          "step": 1,
          "unit": "deg",
          "default": 0
        },
        {
          "type": "range",
          "id": "offset_y",
          "label": "Décalage vertical (vers le bas)",
          "min": 0,
          "max": 120,
          "step": 2,
          "unit": "px",
          "default": 0
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Instagram shots",
      "blocks": [
        { "type": "photo", "settings": { "rotation": -4, "offset_y": 24 } },
        { "type": "photo", "settings": { "rotation": 3, "offset_y": 0 } },
        { "type": "photo", "settings": { "rotation": -2, "offset_y": 44 } },
        { "type": "photo", "settings": { "rotation": 4, "offset_y": 12 } }
      ]
    }
  ]
}
{% endschema %}
