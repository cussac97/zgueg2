{%- liquid
  assign sid = section.id
-%}

<div class="zg-study" id="zg-study-{{ sid }}">
  <div class="zg-study__container">
    {%- if section.settings.heading != blank -%}
      <{{ section.settings.seo_h_tag }} class="zg-study__heading">{{ section.settings.heading }}</{{ section.settings.seo_h_tag }}>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="zg-study__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="zg-study__table" role="table">
      {%- for block in section.blocks -%}
        <div class="zg-study__row" role="row" {{ block.shopify_attributes }}>
          <span class="zg-study__value" role="cell">{{ block.settings.value }}</span>
          <span class="zg-study__label" role="cell">{{ block.settings.label }}</span>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.footnote != blank -%}
      <div class="zg-study__footnote">{{ section.settings.footnote }}</div>
    {%- endif -%}
  </div>
</div>

<style>
  #zg-study-{{ sid }} {
    background-color: {{ section.settings.section_bg }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  #zg-study-{{ sid }} .zg-study__container {
    max-width: 1040px;
    margin: 0 auto;
    padding-left: 24px;
    padding-right: 24px;
  }
  #zg-study-{{ sid }} .zg-study__heading {
    margin: 0;
    text-align: center;
    color: {{ section.settings.heading_color }};
    font-size: {{ section.settings.heading_size }}px;
    font-weight: {{ section.settings.heading_weight }};
    line-height: 1.15;
  }
  #zg-study-{{ sid }} .zg-study__subheading {
    margin: 14px 0 0;
    text-align: center;
    color: {{ section.settings.muted_color }};
    font-size: {{ section.settings.subheading_size }}px;
    line-height: 1.5;
  }
  #zg-study-{{ sid }} .zg-study__table {
    margin-top: 42px;
    border-top: 1px solid {{ section.settings.line_color }};
  }
  #zg-study-{{ sid }} .zg-study__row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 24px;
    padding: {{ section.settings.row_padding }}px 20px;
    border-bottom: 1px solid {{ section.settings.line_color }};
  }
  #zg-study-{{ sid }} .zg-study__row:nth-child(odd) {
    background-color: {{ section.settings.stripe_color }};
  }
  #zg-study-{{ sid }} .zg-study__value {
    flex: 0 0 auto;
    color: {{ section.settings.value_color }};
    font-size: {{ section.settings.value_size }}px;
    font-weight: 700;
    line-height: 1;
    white-space: nowrap;
  }
  #zg-study-{{ sid }} .zg-study__label {
    flex: 0 1 auto;
    text-align: right;
    color: {{ section.settings.text_color }};
    font-size: {{ section.settings.label_size }}px;
    font-weight: 600;
    line-height: 1.4;
  }
  #zg-study-{{ sid }} .zg-study__footnote {
    margin-top: 18px;
    text-align: center;
    color: {{ section.settings.muted_color }};
    font-size: 13px;
  }
  #zg-study-{{ sid }} .zg-study__footnote p { margin: 0; }
  @media (max-width: 749px) {
    #zg-study-{{ sid }} .zg-study__heading { font-size: {{ section.settings.heading_size_mobile }}px; }
    #zg-study-{{ sid }} .zg-study__value { font-size: {{ section.settings.value_size | times: 0.72 | round }}px; }
    #zg-study-{{ sid }} .zg-study__label { font-size: {{ section.settings.label_size | minus: 1 }}px; }
    #zg-study-{{ sid }} .zg-study__row { padding-left: 12px; padding-right: 12px; }
  }
</style>

{% schema %}
{
  "name": "Résultats d'usage",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Les chiffres qui comptent"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Sous-titre",
      "default": "Ce que ça change, concrètement"
    },
    {
      "type": "richtext",
      "id": "footnote",
      "label": "Note de bas de tableau"
    },
    {
      "type": "header",
      "content": "Typographie"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Taille du titre",
      "min": 20,
      "max": 80,
      "step": 2,
      "default": 44
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Taille du titre (mobile)",
      "min": 18,
      "max": 48,
      "step": 2,
      "default": 30
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Graisse du titre",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "400"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Taille du sous-titre",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 15
    },
    {
      "type": "range",
      "id": "value_size",
      "label": "Taille des valeurs",
      "min": 24,
      "max": 80,
      "step": 2,
      "default": 44
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Taille des libellés",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 15
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Fond de section",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Couleur du titre",
      "default": "#0000c9"
    },
    {
      "type": "color",
      "id": "value_color",
      "label": "Couleur des valeurs",
      "default": "#0000c9"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur des libellés",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Couleur secondaire",
      "default": "#4f4f4f"
    },
    {
      "type": "color",
      "id": "stripe_color",
      "label": "Fond des lignes impaires",
      "default": "#eef1fd"
    },
    {
      "type": "color",
      "id": "line_color",
      "label": "Couleur des séparateurs",
      "default": "#e6e6e6"
    },
    {
      "type": "header",
      "content": "Espacements"
    },
    {
      "type": "range",
      "id": "row_padding",
      "label": "Hauteur des lignes",
      "min": 8,
      "max": 40,
      "step": 2,
      "default": 18
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Marge haute",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Marge basse",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 80
    },
    {
      "type": "select",
      "id": "seo_h_tag",
      "label": "Balise SEO du titre",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "span", "label": "Span" }
      ],
      "default": "h2"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Statistique",
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Valeur",
          "default": "95%"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Libellé",
          "default": "constatent une vraie différence au quotidien"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Résultats d'usage",
      "blocks": [
        { "type": "stat" },
        { "type": "stat" },
        { "type": "stat" }
      ]
    }
  ]
}
{% endschema %}
