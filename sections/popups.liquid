{%- if section.blocks.size > 0 or settings.cart_mini_enabled -%}
  <div class="stacked-popups stacked-popups--align-{{ section.settings.alignment }}">
    {%- if settings.cart_mini_enabled -%}
      <modal-box
        id="mini-cart-popup"
        class="popup popup-block popup--cart popup-size--small"
        data-options='
          {
            "enabled": false,
            "showOnce": false,
            "closeByKey": false,
            "disableScroll": false
          }
        '
        style="display:none"
        data-hide="{{ settings.cart_mini_hide | times: 1000 }}"
      >
        <div class="mini-cart-popup gutter--regular spacing--xlarge remove-empty-space">
          <svg
            class="mini-cart-popup__checkmark"
            version="1.1"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 130.2 130.2"
          >
            <circle class="path circle" fill="none" stroke="{{ settings.cart_mini_checkmark }}" stroke-width="6" stroke-miterlimit="10" cx="65.1" cy="65.1" r="62.1"/>
            <polyline class="path check" fill="none" stroke="{{ settings.cart_mini_checkmark }}" stroke-width="6" stroke-linecap="round" stroke-miterlimit="10" points="100.2,40.2 51.5,88.8 29.8,67.5 "/>
          </svg>

          <div class="mini-cart-popup__text line-height--medium">
            <div data-js-mini-cart-single style="display:none">{{ 'cart.added_items_count.one_html' | t }}</div>
            <div data-js-mini-cart-plural style="display:none"></div>
          </div>

          <a
            class="button button--fullwidth button--icon"
            {% if settings.cart_action == 'overlay' and template != 'cart' %}
              data-js-sidebar-handle aria-expanded="false" aria-controls="site-cart-sidebar" role="button"
              data-js-close
            {% else %}
              href="{{ routes.cart_url }}"
            {% endif %}
            title="{{ 'general.accessibility_labels.open_cart' | t }}"
            tabindex="0"
          >
            <span class="button__icon" role="img" aria-hidden="true">
              {%- render 'theme-symbols', icon: 'arrow-right' -%}
            </span>
            <span class="button__text">{{ 'cart.view_cart' | t }}</span>
          </a>
        </div>

        {% style %}
          .popup--cart {
            background: {{ settings.cart_mini_background }} !important;
            color: {{ settings.cart_mini_text }} !important;
            border: 0 !important;
            border-radius: {{ settings.cart_mini_radius }}px !important;
            {%- if settings.cart_mini_shadow -%}
              box-shadow: 0 0 5px 1px rgb(0 0 0 / 16%);
            {%- endif -%}
          }
          .popup--cart .button {
            border-color: {{ settings.cart_mini_text }};
            color: {{ settings.cart_mini_text }};
          }
          .popup--cart .popup-close rect,
          .popup--cart .button path {
            fill: {{ settings.cart_mini_text }} !important;
          }
        {% endstyle %}

        <button class="popup-close" data-js-close>
          <span class="visually-hidden">{{ 'general.accessibility_labels.close' | t }}</span>
          <span aria-hidden="true" class="exit">{%- render 'theme-symbols', icon: 'close-small' -%}</span>
        </button>
      </modal-box>
    {%- endif -%}

    {%- for block in section.blocks -%}
      {%- liquid
        assign show = false

        if block.type == 'cookies'
          assign show = true
        elsif block.settings.visibility == 'all'
          assign show = true
        elsif block.settings.visibility == 'homepage' and template == 'index'
          assign show = true
        elsif block.settings.visibility == 'no-homepage' and template != 'index'
          assign show = true
        elsif block.settings.visibility == 'product' and template contains 'product'
          assign show = true
        elsif block.settings.visibility == 'cart' and template contains 'cart'
          assign show = true
        endif
      -%}

      {%- if show -%}
        {%- if block.type == 'cookies' or block.settings.enable or request.design_mode -%}
          {%- liquid
            if block.type == 'cookies'
              assign freq = 'month'
            else
              assign freq = block.settings.show_repeat
            endif
            if block.type == 'custom' or block.type == 'image'
              assign size = block.settings.box_size
            elsif block.type == 'newsletter'
              assign size = block.settings.box_size | default: 'small'
            else
              assign size = 'small'
            endif
          -%}
          <modal-box
            id="modal-{{ block.id }}"
            class="popup popup-block popup--{{ block.type }} popup-size--{{ size }} {% if block.settings.popup_box_shadow %} popup--has-shadow {% endif %}"
            data-options='
              {
                {% if block.type == 'cookies' %}
                "show": {% unless request.design_mode %} 1 {% else %} 1000 {% endunless %},
                "enabled": true,
                {% else %}
                "show": {% unless request.design_mode %} {{ block.settings.show_after }} {% else %} 1000 {% endunless %},
                "enabled": {{ block.settings.enable }},
                "showOnPageOffset": {% if  block.settings.show_after_scroll %} {{ block.settings.page_offset }} {% else %} -1 {% endif %},
                {% endif %}
                "frequency": "{{ freq }}",
                {% if block.type == 'cookies' and request.design_mode == false %} "type": "cookies", {% endif %}
                "closeByKey": false,
                "disableScroll": false
              }
            '
            style="display:none;"
            data-modal-box
            {{ block.shopify_attributes }}
          >
            {%- case block.type -%}
              {%- when 'product' -%}
                {% liquid
                  if block.settings.popup_product != blank
                    assign product = block.settings.popup_product
                    assign blank_product = false
                  else
                    assign blank_product = true
                  endif
                %}
                <div class="popup-product">
                  <div class="spacing--large remove-empty-space">
                    {%- if block.settings.title -%}
                      <div class="popup-heading">
                        <span class="text-weight--bold">{{ block.settings.title | escape }}</span>
                      </div>
                    {%- endif -%}
                    <div class="popup-product_layout">
                      <div class="popup-product_image">
                        <a href="{{ product.url }}" title="{{ product.title | escape }}">
                          {%- liquid
                            unless blank_product
                              render 'lazy-image-small', image: product.featured_media, aspect_ratio: settings.cart_image_ratio, fit: settings.cart_image_fit, class: 'lazy-image--scale-animation'
                            else
                              render 'lazy-svg', image: 'product', ratio: 0.7, class: 'svg-placeholder svg-placeholder--background'
                            endunless
                          -%}
                        </a>
                      </div>
                      <div class="popup-product_info">
                        <div class="product-item__price text-size--small equalize-white-space">
                          <div class="" data-js-product-item-price>
                            {%- liquid
                              unless blank_product
                                assign product_variant = product.selected_or_first_available_variant
                                render 'product-price', target: product, variant: product_variant, product_price_varies: product.price_varies
                              else
                                echo 9999 | money
                              endunless
                            -%}
                          </div>
                        </div>

                        <a
                          class="product-item__title"
                          href="{{ product.url }}"
                          title="{{ product.title | escape }}"
                        >
                          <div class="remove-line-height-space--small">
                            <span class="text-animation--underline-thin text-size--large text-weight--bold">
                              {%- liquid
                                unless blank_product
                                  echo product.title | escape
                                else
                                  echo 'general.onboarding.product_title' | t
                                endunless
                              -%}
                            </span>
                          </div>
                        </a>
                        {%- if product.metafields.reviews.size > 0 -%}
                          <div class="product-item__ratings" style="padding-top: 14px">
                            {%- render 'product-rating',
                              vendor: settings.reviews_app,
                              product: product,
                              hide_no_reviews_on_mobile: true
                            -%}
                          </div>
                        {%- endif -%}
                      </div>
                    </div>
                  </div>
                </div>

              {%- when 'cookies' -%}
                {%- liquid
                  assign shopify_desc_default = 'Indispensables au fonctionnement de la boutique : panier, commande, sécurité.'
                  assign meta_desc_default = 'Facebook & Instagram : mesure et personnalisation de nos publicités.'
                  assign tiktok_desc_default = 'Suivi de nos campagnes et de nos vidéos TikTok.'
                  assign ga_desc_default = "Mesure d'audience, pour savoir ce qui vous plaît sur le site."
                -%}
                <div class="popup-text gutter--regular spacing--large remove-empty-space cookies-card" data-cookie-card data-prefs-link-label="{{ block.settings.prefs_link_label | default: 'Préférences de cookies' | escape }}" style="--cookie-accent: {{ block.settings.toggle_color | default: '#1f49ff' }};">

                  {%- comment -%} Vue principale : consentement {%- endcomment -%}
                  <div class="cookies-main">
                    <div>
                      <span class="popup-title">{{ block.settings.title | default: "Salut c'est nous… 🍪 les cookies !" }}</span>
                    </div>
                    <div class="rte text-size--small cookies-desc">
                      {{ block.settings.content | default: "<p>On a attendu d'être sûrs que nos zgueg vous plaisent avant de venir vous déranger. Maintenant qu'on est là, on aimerait bien vous accompagner tranquillement pendant votre visite — promis, on reste bien plus discrets que certaines odeurs. 😏</p><p>C'est ok pour vous ? Vous pourrez changer d'avis quand vous voulez via le lien « Préférences de cookies » en bas de page.</p>" }}
                    </div>
                    <div class="increased-spacing cookies-actions">
                      {%- render 'button',
                        style: 'solid',
                        fullwidth: true,
                        label: block.settings.accept_label,
                        label_is_translation: false,
                        type: 'button',
                        attribute: 'data-js-close data-js-cookies-accept'
                      -%}
                      {%- render 'button',
                        style: 'outline',
                        fullwidth: true,
                        label: block.settings.customize_label,
                        label_is_translation: false,
                        type: 'button',
                        attribute: 'data-js-cookies-customize'
                      -%}
                    </div>
                  </div>

                  {%- comment -%} Vue préférences : interrupteurs par catégorie {%- endcomment -%}
                  <div class="cookies-prefs">
                    <div>
                      <span class="popup-title">{{ block.settings.prefs_title | default: 'Vos préférences cookies' }}</span>
                    </div>
                    <div class="cookie-rows">
                      <div class="cookie-row">
                        <div class="cookie-row__text">
                          <div class="cookie-row__label">{{ block.settings.cat_shopify_label | default: 'Cookies Shopify' }}</div>
                          <div class="cookie-row__desc">{{ block.settings.cat_shopify_desc | default: shopify_desc_default }}</div>
                        </div>
                        <label class="cookie-switch">
                          <input type="checkbox" data-cookie-toggle="shopify" checked aria-label="{{ block.settings.cat_shopify_label | default: 'Cookies Shopify' | escape }}">
                          <span class="cookie-switch__track"></span>
                        </label>
                      </div>
                      <div class="cookie-row">
                        <div class="cookie-row__text">
                          <div class="cookie-row__label">{{ block.settings.cat_meta_label | default: 'Cookies Meta' }}</div>
                          <div class="cookie-row__desc">{{ block.settings.cat_meta_desc | default: meta_desc_default }}</div>
                        </div>
                        <label class="cookie-switch">
                          <input type="checkbox" data-cookie-toggle="meta" checked aria-label="{{ block.settings.cat_meta_label | default: 'Cookies Meta' | escape }}">
                          <span class="cookie-switch__track"></span>
                        </label>
                      </div>
                      <div class="cookie-row">
                        <div class="cookie-row__text">
                          <div class="cookie-row__label">{{ block.settings.cat_tiktok_label | default: 'Cookies TikTok' }}</div>
                          <div class="cookie-row__desc">{{ block.settings.cat_tiktok_desc | default: tiktok_desc_default }}</div>
                        </div>
                        <label class="cookie-switch">
                          <input type="checkbox" data-cookie-toggle="tiktok" checked aria-label="{{ block.settings.cat_tiktok_label | default: 'Cookies TikTok' | escape }}">
                          <span class="cookie-switch__track"></span>
                        </label>
                      </div>
                      <div class="cookie-row">
                        <div class="cookie-row__text">
                          <div class="cookie-row__label">{{ block.settings.cat_ga_label | default: 'Cookies Google Analytics' }}</div>
                          <div class="cookie-row__desc">{{ block.settings.cat_ga_desc | default: ga_desc_default }}</div>
                        </div>
                        <label class="cookie-switch">
                          <input type="checkbox" data-cookie-toggle="ga" checked aria-label="{{ block.settings.cat_ga_label | default: 'Cookies Google Analytics' | escape }}">
                          <span class="cookie-switch__track"></span>
                        </label>
                      </div>
                    </div>
                    <div class="cookies-actions">
                      {%- render 'button',
                        style: 'solid',
                        fullwidth: true,
                        label: block.settings.save_label,
                        label_is_translation: false,
                        type: 'button',
                        attribute: 'data-js-close data-js-cookies-save'
                      -%}
                    </div>
                    <button type="button" class="cookies-back" data-js-cookies-back>{{ block.settings.back_label | default: 'Retour' }}</button>
                  </div>
                </div>

                <style>
                  .popup--cookies .popup-title { display:block; font-size:20px; line-height:1.25; font-weight:700; margin-bottom:12px; }
                  .popup--cookies .cookies-desc p { margin:0 0 10px; }
                  .popup--cookies .cookies-desc p:last-child { margin-bottom:0; }
                  .popup--cookies .cookies-prefs { display:none; }
                  .popup--cookies.cookies-prefs-open .cookies-main { display:none; }
                  .popup--cookies.cookies-prefs-open .cookies-prefs { display:block; }
                  .popup--cookies .cookies-actions { display:flex; flex-direction:column; gap:10px; margin-top:18px; }
                  .popup--cookies .cookie-rows { margin-top:10px; }
                  .popup--cookies .cookie-row { display:flex; align-items:flex-start; justify-content:space-between; gap:16px; padding:14px 0; border-bottom:1px solid rgba(127,127,127,.22); }
                  .popup--cookies .cookie-row:last-child { border-bottom:0; }
                  .popup--cookies .cookie-row__label { font-weight:600; }
                  .popup--cookies .cookie-row__desc { font-size:13px; opacity:.72; margin-top:3px; line-height:1.4; }
                  .popup--cookies .cookie-switch { position:relative; flex:0 0 auto; width:46px; height:26px; display:inline-block; }
                  .popup--cookies .cookie-switch input { position:absolute; inset:0; opacity:0; margin:0; cursor:pointer; z-index:1; background:transparent !important; border:0 !important; }
                  .popup--cookies .cookie-switch__track { position:absolute; inset:0; border-radius:999px; background:rgba(127,127,127,.4); transition:background .2s ease; pointer-events:none; }
                  .popup--cookies .cookie-switch__track::after { content:""; position:absolute; top:3px; left:3px; width:20px; height:20px; border-radius:50%; background:#fff; transition:transform .2s ease; }
                  .popup--cookies .cookie-switch input:checked ~ .cookie-switch__track { background: var(--cookie-accent, #1f49ff); }
                  .popup--cookies .cookie-switch input:checked ~ .cookie-switch__track::after { transform: translateX(20px); }
                  .popup--cookies .cookie-switch input:focus-visible ~ .cookie-switch__track { outline:2px solid var(--cookie-accent, #1f49ff); outline-offset:2px; }
                  .popup--cookies .cookies-back { display:block; margin:14px auto 0; background:none; border:0; font:inherit; cursor:pointer; text-decoration:underline; opacity:.7; }
                  .zgueg-cookie-prefs-link { width:100%; text-align:center; padding:16px 12px; }
                  .zgueg-cookie-prefs-link button { background:none; border:0; font:inherit; cursor:pointer; text-decoration:underline; opacity:.6; padding:4px; }
                  .zgueg-cookie-prefs-link button:hover { opacity:1; }
                </style>

              {%- when 'newsletter' -%}
                <div class="popup-newsletter{% if block.settings.image != blank %} popup-newsletter--with-image popup-newsletter--mobile-{{ block.settings.mobile_layout | default: 'vertical' }}{% endif %}"{% if block.settings.image != blank %} style="--popup-img-width: {{ block.settings.image_width | default: 45 }}%; --popup-img-padding: {{ block.settings.image_padding | default: 16 }}px; --popup-img-mobile-width: {{ block.settings.mobile_image_width | default: 40 }}%; --popup-img-mobile-height: {{ block.settings.mobile_image_height | default: 160 }}px;"{% endif %}>
                  {%- if block.settings.image != blank -%}
                    <div class="popup-newsletter__media">
                      <img
                        src="{{ block.settings.image | image_url: width: 800 }}"
                        srcset="{{ block.settings.image | image_url: width: 400 }} 400w, {{ block.settings.image | image_url: width: 800 }} 800w"
                        sizes="(max-width: 767px) 100vw, 45vw"
                        width="{{ block.settings.image.width }}"
                        height="{{ block.settings.image.height }}"
                        loading="lazy"
                        alt="{{ block.settings.image.alt | escape }}"
                      >
                    </div>
                  {%- endif -%}
                  <div class="popup-text gutter--regular">
                  {%- assign form_id = 'newsletter-' | append: block.id -%}
                  {%- form 'customer', id: form_id, class: '' -%}
                    <div class="spacing--large remove-empty-space">
                      <div>
                        <span class="popup-title">{{ block.settings.title | escape }}</span>
                      </div>
                      <div class="rte remove-empty-space text-size--small">
                        {%- liquid
                          if form.posted_successfully?
                            echo 'general.newsletter.confirmation' | t
                          else
                            echo block.settings.content
                          endif
                        -%}
                      </div>
                    </div>

                    {%- unless form.posted_successfully? -%}
                      <fieldset>
                        <input type="hidden" name="contact[tags]" value="newsletter">
                        <div class="form-row" style="position:relative">
                          <input
                            type="email"
                            class="newsletter__input"
                            value="{% if customer %}{{ customer.email }}{% endif %}"
                            placeholder="{{ 'general.newsletter.email_label' | t }}"
                            name="contact[email]"
                            id="Email-{{ form_id }}"
                            aria-label="{{ 'general.newsletter.email_label' | t }}"
                            autocorrect="off"
                            autocapitalize="off"
                            required
                          >
                          <button
                            type="submit"
                            id="Subscribe-{{ form_id }}"
                            aria-label="{{ 'general.newsletter.submit_label' | t }}"
                          >
                            <span class="visually-hidden">{{ 'general.newsletter.submit_label' | t }}</span>
                            <span aria-hidden="true" role="img">{%- render 'theme-symbols', icon: 'send' -%}</span>
                          </button>
                        </div>
                      </fieldset>
                    {%- endunless -%}
                  {%- endform -%}
                  </div>
                </div>

              {%- when 'custom' -%}
                <div class="popup-text gutter--regular">
                  <div class="spacing--large remove-empty-space">
                    {%- if block.settings.title -%}
                      <div>
                        <span class="popup-title">{{ block.settings.title | escape }}</span>
                      </div>
                    {%- endif -%}

                    {%- if block.settings.content -%}
                      <div class="rte remove-empty-space text-size--small">{{ block.settings.content }}</div>
                    {%- endif -%}
                  </div>
                </div>

              {%- when 'image' -%}
                <div class="popup-text {% unless block.settings.image %}popup-text--no-content{% endunless %}">
                  <div class="spacing--large remove-empty-space">
                    {%- if block.settings.image -%}
                      {%- if block.settings.link -%}
                        <a href="{{ block.settings.link }}" target="{{ block.settings.link_type }}">
                      {%- endif -%}
                      {%- render 'lazy-image', image: block.settings.image, type: '' -%}
                      {%- if block.settings.link -%}</a>{%- endif -%}
                    {%- else -%}
                      {%- liquid
                        if block.settings.box_size == 'small'
                          assign sizes = 'sizes="340px"'
                        else
                          assign sizes = 'sizes="(max-width: 640px) calc(100vw - 30px), 540px"'
                        endif
                        render 'lazy-svg', image: 'image', ratio: 1.5, class: 'svg-placeholder svg-placeholder--foreground', sizes: sizes
                      -%}
                    {%- endif -%}
                  </div>
                </div>
            {%- endcase -%}

            {%- unless block.type == 'cookies' -%}
              <button class="popup-close" data-js-close>
                <span class="visually-hidden">{{ 'general.accessibility_labels.close' | t }}</span>
                <span aria-hidden="true" class="exit">{%- render 'theme-symbols', icon: 'close' -%}</span>
              </button>
            {%- endunless -%}

            <div data-content style="display:none" aria-hidden="true">{{ block.type }}-{{ block.id }}</div>

            <style>
                {%- if block.settings.popup_txtcolor != 'rgba(0,0,0,0)' -%}
                  {%- assign popup_txtcolor = block.settings.popup_txtcolor -%}
                  #modal-{{ block.id }},
                  #modal-{{ block.id }} a {
                    color: {{ popup_txtcolor }};
                  }
                  #modal-{{ block.id }} svg path {
                    stroke: {{ popup_txtcolor }};
                  }
                  #modal-{{ block.id }} .button,
                  #modal-{{ block.id }} input {
                    border-color: {{ popup_txtcolor }};
                    color: {{ popup_txtcolor }};
                    background: transparent;
                  }
                  #modal-{{ block.id }} .button--solid {
                    border-color: {{ popup_txtcolor }};
                    color: {{ block.settings.popup_bgcolor }};
                    background: {{ popup_txtcolor }};
                  }

                  #modal-{{ block.id }} .button--solid:hover svg path {
                    stroke: {{ block.settings.popup_bgcolor }} ;
                  }
                  #modal-{{ block.id }} input::placeholder {
                    color: {{ popup_txtcolor }};
                  }
                {%- endif -%}

                {%- if block.settings.popup_bgcolor != 'rgba(0,0,0,0)' -%}
                  #modal-{{ block.id }} {
                    background: {{ block.settings.popup_bgcolor }};
                    border: none;
                  }
                {%- endif -%}

                {%- if block.settings.popup_heading_bgcolor != 'rgba(0,0,0,0)' -%}
                #modal-{{ block.id }} .popup-heading {
                  background-color: {{ block.settings.popup_heading_bgcolor }};
                }
              {%- endif -%}
            </style>
          </modal-box>
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}
  </div>

  {% style %}
    #shopify-section-{{ section.id }} modal-box,
    #shopify-section-{{ section.id }} modal-box img {
      border-radius: {{ section.settings.popup_border_radius }}px;
    }
  {% endstyle %}
{%- endif -%}

{% schema %}
{
  "name": "t:sections.local-extra-words.sections.popups.name",
  "max_blocks": 12,
  "blocks": [
    {
      "type": "image",
      "name": "t:sections.gallery.blocks.image.settings.image.label",
      "settings": [
        {
          "type": "checkbox",
          "id": "enable",
          "label": "t:sections.popup.settings.enable.label",
          "default": false
        },
        {
          "type": "select",
          "id": "visibility",
          "label": "t:sections.refactor_words.announcement-bar.visibility.label",
          "options": [
            {
              "value": "all",
              "label": "t:sections.refactor_words.announcement-bar.visibility.option_1"
            },
            {
              "value": "homepage",
              "label": "t:sections.refactor_words.announcement-bar.visibility.option_2"
            },
            {
              "value": "product",
              "label": "t:sections.refactor_words.announcement-bar.visibility.option_4"
            },
            {
              "value": "cart",
              "label": "t:sections.refactor_words.announcement-bar.visibility.option_5"
            },
            {
              "value": "no-homepage",
              "label": "t:sections.refactor_words.announcement-bar.visibility.option_3"
            }
          ],
          "default": "all"
        },
        {
          "type": "header",
          "content": "t:sections.local-extra-words.sections.faq.headings.content"
        },
        {
          "id": "image",
          "type": "image_picker",
          "label": "t:sections.gallery.blocks.image.settings.image.label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.image-with-text.blocks.image.settings.url.label"
        },
        {
          "type": "select",
          "id": "link_type",
          "label": "t:sections.local-extra-words.sections.header.blocks.info.link_type.label",
          "options": [
            {
              "value": "_blank",
              "label": "t:sections.local-extra-words.sections.header.blocks.info.link_type.option__3"
            },
            {
              "value": "_self",
              "label": "t:sections.local-extra-words.sections.header.blocks.info.link_type.option__2"
            }
          ],
          "default": "_self"
        },
        {
          "type": "range",
          "id": "show_after",
          "label": "t:sections.popup.settings.show_after.label",
          "min": 1,
