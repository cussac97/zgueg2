        "collapsible_tab_P4hk8m": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Ingrédients",
            "content": "<ul><li>Ferments probiotiques (Lactobacillus, Bifida)</li><li>Eau d'armoise (Artemisia)</li><li>Centella asiatica</li><li>Houttuynia cordata</li><li>Thé vert (Camellia sinensis)</li><li>Glycérine végétale</li><li>Sans alcool, sans parfum de synthèse</li></ul>",
