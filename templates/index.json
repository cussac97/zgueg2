      "blocks": {
        "review_JnBAQ3": {
          "type": "review",
          "settings": {
            "author": "Mary H.",
            "verified": true,
            "verified_label": "Verified Buyer",
            "rating": 4,
            "date": "May 22, 2026",
            "product": "",
            "text": "Love all the products, but this one didn't do as well. I think the 5 pant is bigger than the 5 diaper, IMO. We struggled with some leakage, but once I got them on my daughter right they were fine. My biggest issue was through the night. They are not nearly as absorbent as the diapers. Many mornings we woke up to accidents. I switched back to the originals.",
            "helpful_up": 0,
            "helpful_down": 0,
            "reply_enable": false,
            "reply_avatar_bg": "#1f49ff",
            "reply_author": "Chloe",
            "reply_date": "May 21, 2026",
            "reply_text": ""
          }
        },
        "review_dPmihX": {
          "type": "review",
          "settings": {
            "author": "Chandana M.",
            "verified": true,
            "verified_label": "Verified Buyer",
            "rating": 3,
            "date": "May 22, 2026",
            "product": "",
            "text": "Like the product but the stick is too fragile. It comes off when I'm taking it off the package. I would have liked the sticking part design to be better.",
            "helpful_up": 0,
            "helpful_down": 0,
            "reply_enable": false,
            "reply_avatar_bg": "#1f49ff",
            "reply_author": "Chloe",
            "reply_date": "May 21, 2026",
            "reply_text": ""
          }
        },
        "review_WhmgKB": {
          "type": "review",
          "settings": {
            "author": "Erin H.",
            "verified": true,
            "verified_label": "Verified Buyer",
            "rating": 5,
            "date": "May 21, 2026",
            "product": "",
            "text": "We have been loving it. It is so easy to change with the tabs on the side yet gives our 21 month old the practice she needs pulling them up and down for potty training.",
            "helpful_up": 0,
            "helpful_down": 0,
            "reply_enable": true,
            "reply_avatar_bg": "#1f49ff",
            "reply_author": "Chloe",
            "reply_date": "May 21, 2026",
            "reply_text": "Thanks, Erin H.! We're thrilled the side tabs are making potty training smoother and giving her confident pull-up practice. Our mission is to make parents' lives easier."
          }
        }
      },
