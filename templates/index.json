    "rich_text_9XNcQB": {
      "type": "rich-text",
      "blocks": {
        "title_x7jGrL": {
          "type": "title",
          "settings": {
            "title": "L'histoire de deux 🍆 qui ont créé Zgueg®",
            "title_size": "heading-size--small",
            "title_weight": "500",
            "title_size_custom": 0,
            "title_size_custom_mobile": 0,
            "seo_h_tag": "h2"
          }
        },
        "text_UYMML3": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Hello ! Nous, c'est Ben et Julien </strong>👋</p><p>Deux amis de longue date.</p><p>Un soir, autour d'un verre, on s'est demandé comment arriver à un date avec cette vraie confiance d'être frais, propre, irréprochable jusque dans l'intime.</p><p>On s'est partagé nos astuces. Puis on a compris qu'aucune solution n'était vraiment pensée pour les hommes.</p><p>Alors pendant plus de deux ans, avec des pharmaciens et cosmétologues, on a travaillé sur une formule sérieuse, clean et efficace.</p><p>Parce que l'intime masculin méritait enfin mieux qu'un tabou.</p><p><strong>Zgueg® est né comme ça : d'une amitié, d'une conversation honnête, et de l'envie de créer le produit qu'on aurait aimé avoir.</strong></p>",
            "text_size": "regular"
          }
        }
      },
